# ---------------------------------------------------------------------------
# FinSage-7B frontend environment.
# Copy to `.env.local` for local development. Never commit `.env.local`.
#
# IMPORTANT: Do NOT put production secrets in NEXT_PUBLIC_* variables — anything
# prefixed with NEXT_PUBLIC_ is inlined into the browser bundle and is public.
# The API secret is read server-side only (app/api/* routes) and stays private.
# ---------------------------------------------------------------------------

# Server-side only (used by the Next.js /api proxy routes; never sent to the browser)
API_BASE_URL=http://localhost:8080/v1
API_SECRET_KEY=change-me

# Public (safe to expose in the browser bundle)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_NAME=FinSage-7B
