# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
deployment-bundle/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
*.local
*.log
logs/
api_keys.txt

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Project artifacts (large / generated) — kept out of git
# ---------------------------------------------------------------------------
checkpoints/
models/
wandb/
mlruns/
runs/
outputs/
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.gguf

# Raw / processed / cached SEC data — never commit filings (only .gitkeep / cards)
data/raw/*
data/processed/*
data/cache/*
data/datasets/*
!data/**/.gitkeep
!data/dataset_card.md

# Filing HTML anywhere (but keep small test fixtures)
*.html
*.htm
!tests/fixtures/**

# Generated report figures (raw eval artifacts stay local; keep the polished
# benchmark-report charts so the committed report renders on GitHub).
reports/figures/*
!reports/figures/.gitkeep
!reports/figures/report_*.png

# Benchmark report (Phase 11): keep the Markdown, PDF, metadata and the
# PDF-skip note; HTML is covered by the *.html rule above. Drop scratch assets.
!reports/benchmark_report.md
!reports/benchmark_report.pdf
!reports/report_metadata.json
!reports/PDF_EXPORT_SKIPPED.md
reports/report_assets/*.tmp

# ---------------------------------------------------------------------------
# Frontend (Phase 9: Next.js demo)
# ---------------------------------------------------------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/coverage/
tests/fixtures/reporting/report_*.png
