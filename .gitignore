# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
*.local

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Project artifacts (large / generated) — kept out of git
# ---------------------------------------------------------------------------
checkpoints/
models/
wandb/
mlruns/
runs/
outputs/
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.gguf

# Raw / processed / cached SEC data — never commit filings (only .gitkeep / cards)
data/raw/*
data/processed/*
data/cache/*
data/datasets/*
!data/**/.gitkeep
!data/dataset_card.md

# Filing HTML anywhere (but keep small test fixtures)
*.html
*.htm
!tests/fixtures/**

# Generated report figures
reports/figures/*
!reports/figures/.gitkeep
