# vLLM serving image for FinSage-7B (Phase 7).
#
# REQUIRES an NVIDIA GPU at runtime + the NVIDIA Container Toolkit:
#   docker run --gpus all ...   (or `deploy.resources` in docker-compose.yml)
#
# vLLM is tightly coupled to specific CUDA/torch versions. This image pins a
# CUDA 12.1 runtime base; if `pip install vllm` resolves a wheel built for a
# different CUDA, either switch the base tag to match (e.g. cuda:12.4.x) or use
# the official `vllm/vllm-openai:latest` image and mount the merged model.
FROM nvidia/cuda:12.1.1-runtime-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip git curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install the package with the serving extra (pulls vLLM). Copy metadata + source
# first for better layer caching.
COPY pyproject.toml README.md ./
COPY src ./src
RUN python3 -m pip install --upgrade pip && python3 -m pip install -e ".[serving]"

# Serving scripts + configs.
COPY serving ./serving
COPY configs ./configs
RUN chmod +x serving/vllm_server.sh serving/vllm_lora_server.sh

EXPOSE 8000

# The merged model is mounted at runtime (see docker-compose.yml):
#   -v $(pwd)/checkpoints/finsage-7b-merged:/models/finsage-7b-merged:ro
# and MODEL_PATH points at it.
CMD ["bash", "serving/vllm_server.sh"]
