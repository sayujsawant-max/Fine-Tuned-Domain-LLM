# vLLM serving image for FinSage-7B (Phase 7).
#
# REQUIRES an NVIDIA GPU at runtime + the NVIDIA Container Toolkit:
#   docker compose -f docker/docker-compose.yml -f docker/docker-compose.gpu.yml up
#   (or `docker run --gpus all ...`)
#
# vLLM is tightly coupled to specific CUDA/torch versions. The CUDA base image
# is parameterised via the CUDA_IMAGE build arg so you can match the wheel that
# `pip install vllm` resolves WITHOUT editing this file:
#
#   docker build -f docker/Dockerfile.serving \
#     --build-arg CUDA_IMAGE=nvidia/cuda:12.4.1-runtime-ubuntu22.04 -t finsage-vllm .
#
# Or set it per-service in compose via `build.args`. Alternatively use the
# official `vllm/vllm-openai:latest` image and mount the merged model.
#
# No secrets are baked in. The merged model is MOUNTED at runtime (read-only)
# and MODEL_PATH points at it (see docker-compose.yml).
ARG CUDA_IMAGE=nvidia/cuda:12.1.1-runtime-ubuntu22.04
FROM ${CUDA_IMAGE}

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip git curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install the package with the serving extra (pulls vLLM). Copy metadata + source
# first for better layer caching.
COPY pyproject.toml README.md ./
COPY src ./src
RUN python3 -m pip install --upgrade pip && python3 -m pip install -e ".[serving]"

# Serving scripts + configs.
COPY serving ./serving
COPY configs ./configs
RUN chmod +x serving/vllm_server.sh serving/vllm_lora_server.sh

EXPOSE 8000

# 7B weights take time to load; the long start-period is set at the compose
# level. This image-level check uses the OpenAI-compatible /v1/models endpoint.
HEALTHCHECK --interval=30s --timeout=10s --start-period=300s --retries=20 \
    CMD curl -f http://localhost:8000/v1/models || exit 1

# The merged model is mounted at runtime:
#   -v $(pwd)/checkpoints/finsage-7b-merged:/models/finsage-7b-merged:ro
CMD ["bash", "serving/vllm_server.sh"]
