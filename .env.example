# ---------------------------------------------------------------------------
# FinSage-7B environment configuration
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Hugging Face token (model/dataset download + Hub upload)
HF_TOKEN=

# Weights & Biases API key (training experiment tracking)
WANDB_API_KEY=

# OpenAI key (only used by the optional LLM-judge during evaluation)
OPENAI_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with contact info, e.g.
# "FinSage Research sayuj@example.com"
EDGAR_USER_AGENT=

# Model + checkpoint paths
MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
ADAPTER_PATH=./checkpoints/finsage-7b-adapter
MERGED_MODEL_PATH=./checkpoints/finsage-7b-merged

# vLLM serving (Phase 7)
MODEL_PATH=checkpoints/finsage-7b-merged
SERVED_MODEL_NAME=finsage-7b
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
MAX_NUM_SEQS=64

# Public FastAPI service
API_HOST=localhost
API_PORT=8080
API_SECRET_KEY=change-me

# Logging
LOG_LEVEL=INFO
