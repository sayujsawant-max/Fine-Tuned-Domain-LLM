# ---------------------------------------------------------------------------
# FinSage-7B — full-stack environment configuration.
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
#
# SECURITY: do not deploy with API_SECRET_KEY=change-me. Anything prefixed
# NEXT_PUBLIC_ is inlined into the browser bundle — never put secrets there.
# ---------------------------------------------------------------------------

# --- General ---------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- API (FastAPI wrapper, Phase 8) ----------------------------------------
# API_SECRET_KEY accepts one key or several comma-separated keys (rotation),
# e.g. API_SECRET_KEY=primary-key,old-key
API_SECRET_KEY=change-this-before-deployment
API_HOST=0.0.0.0
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_REQUESTS_PER_MINUTE=60
# Rate-limit backend: "memory" (default, per-process) or "redis" (shared across
# replicas; requires the `redis` extra + REDIS_URL; falls back to memory if down).
RATE_LIMIT_BACKEND=memory
REDIS_URL=
DISCLAIMER_ENABLED=true
LOG_REQUEST_BODY=false
REQUEST_TIMEOUT_SECONDS=60

# --- vLLM (internal inference server, Phase 7) -----------------------------
MODEL_PATH=checkpoints/finsage-7b-merged
SERVED_MODEL_NAME=finsage-7b
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_BASE_URL=http://localhost:8000/v1
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
MAX_NUM_SEQS=64

# --- Frontend (Next.js demo, Phase 9) --------------------------------------
# API_BASE_URL + API_SECRET_KEY are used server-side by the /api proxy only.
API_BASE_URL=http://localhost:8080/v1
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_APP_NAME=FinSage-7B

# --- Optional external services --------------------------------------------
# Training / dataset tooling only — not needed to run the deployment.
HF_TOKEN=
WANDB_API_KEY=
OPENAI_API_KEY=
EDGAR_USER_AGENT=

# --- Model + checkpoint paths (training/eval phases) -----------------------
MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
ADAPTER_PATH=./checkpoints/finsage-7b-adapter
MERGED_MODEL_PATH=./checkpoints/finsage-7b-merged
